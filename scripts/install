#!/bin/bash
# shellcheck disable=SC2154

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# CONFIGURE LLM BACKEND
#=================================================
ynh_script_progression "Configuring LLM backend..."

# Set defaults for fields that may not have been shown (due to visibility rules)
if [ "$llm_backend" = "ollama" ] || [ "$llm_backend" = "both" ]; then
    ollama_url=$(resolve_ollama_url "$ollama_connection" "$ollama_url")
    ynh_app_setting_set --key=ollama_url --value="$ollama_url"

    # Log Ollama detection status
    ollama_domain=$(detect_ollama_domain)
    if [ -n "$ollama_domain" ]; then
        ynh_print_info "Detected ollama_ynh at ${ollama_domain}"
    fi
else
    ollama_url=""
    ollama_connection="none"
    ynh_app_setting_set --key=ollama_url --value=""
    ynh_app_setting_set --key=ollama_connection --value="none"
fi

if [ "$llm_backend" != "openai" ] && [ "$llm_backend" != "both" ]; then
    openai_api_key=""
    openai_api_base_url=""
    ynh_app_setting_set --key=openai_api_key --value=""
    ynh_app_setting_set --key=openai_api_base_url --value=""
fi

#=================================================
# DETERMINE LOGIN FORM SETTING
#=================================================

# init_main_permission is a special YunoHost question consumed by the permission
# resource system — it may not be exposed as a regular shell variable.
# Use safe expansion with a default of "all_users" (private).
if [ "${init_main_permission:-all_users}" = "visitors" ]; then
    enable_login_form="true"
else
    enable_login_form="false"
fi
ynh_app_setting_set --key=enable_login_form --value="$enable_login_form"

#=================================================
# GET ADMIN EMAIL
#=================================================

admin_email=$(yunohost user info "$admin" --output-as json | python3 -c "import sys,json; print(json.load(sys.stdin)['mail'])")
ynh_app_setting_set --key=admin_email --value="$admin_email"

#=================================================
# CREATE PYTHON VENV AND INSTALL OPEN WEBUI
#=================================================
ynh_script_progression "Setting up Python virtual environment..."

python3 -m venv "$install_dir/venv"
"$install_dir/venv/bin/pip" install --upgrade pip
"$install_dir/venv/bin/pip" install "open-webui==$OPENWEBUI_VERSION"

chown -R "$app:$app" "$install_dir"
chown -R "$app:$app" "$data_dir"

#=================================================
# ADD CONFIGURATION FILES
#=================================================
ynh_script_progression "Adding configuration files..."

ynh_config_add --template=".env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations..."

ynh_config_add_nginx

ynh_config_add_systemd

yunohost service add "$app" --description="Open WebUI AI chat interface" --log="/var/log/$app/$app.log"

mkdir -p "/var/log/$app"
touch "/var/log/$app/$app.log"
chown -R "$app:$app" "/var/log/$app"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start" --log_path="/var/log/$app/$app.log" --wait_until="Uvicorn running" --timeout=240

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
