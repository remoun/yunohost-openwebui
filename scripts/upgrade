#!/bin/bash
# shellcheck disable=SC2154

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# ENSURE DOWNWARD COMPATIBILITY
#=================================================
ynh_script_progression "Ensuring downward compatibility..."

# Ensure settings exist (for upgrades from older versions)
ynh_app_setting_set_default --key=auth_mode --value="sso"
ynh_app_setting_set_default --key=enable_login_form --value="true"
ynh_app_setting_set_default --key=rag_embedding_engine --value="openai"
ynh_app_setting_set_default --key=enable_signup --value="false"
ynh_app_setting_set_default --key=enable_ldap --value="true"
ynh_app_setting_set_default --key=webui_auth_trusted_email_header --value="YNH_USER_EMAIL"
ynh_app_setting_set_default --key=webui_auth_trusted_name_header --value="YNH_USER_FULLNAME"

#=================================================
# UPGRADE PYTHON PACKAGE
#=================================================
ynh_script_progression "Upgrading Open WebUI..."

# Work around yanked ddgs==9.11.2 on PyPI (pinned by Open WebUI 0.8.10):
# install without deps, patch metadata to accept ddgs>=9.11.3, then resolve deps.
"$install_dir/venv/bin/pip" install --upgrade psycopg2-binary
"$install_dir/venv/bin/pip" install --no-deps --upgrade "open-webui==$OPENWEBUI_VERSION"
"$install_dir/venv/bin/pip" install --upgrade "ddgs>=9.11.3"
for _f in "$install_dir"/venv/lib/python3*/site-packages/open_webui-*.dist-info/METADATA; do
    [ -f "$_f" ] && sed -i "s/Requires-Dist: ddgs==9.11.2/Requires-Dist: ddgs>=9.11.3/" "$_f"
done
"$install_dir/venv/bin/pip" install --upgrade "open-webui==$OPENWEBUI_VERSION"

#=================================================
# UPDATE CONFIGURATION FILES
#=================================================
ynh_script_progression "Updating configuration files..."

ynh_config_add --template=".env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations..."

ynh_config_add_nginx

ynh_config_add_systemd

yunohost service add "$app" --description="Open WebUI AI chat interface" --log="/var/log/$app/$app.log"

mkdir -p "/var/log/$app"
touch "/var/log/$app/$app.log"
chown -R "$app:$app" "/var/log/$app"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"
wait_for_port "$port" 240

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
